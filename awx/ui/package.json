    "resolve": "^1.22.12",
    "resolve-url-loader": "^5.0.0",
    "sass-loader": "^16.0.8",
    "semver": "^7.8.5",
    "style-loader": "^4.0.0",
    "styled-components": "^6.4.3",
    "terser-webpack-plugin": "^5.6.0",
    "webpack": "^5.106.2",
    "webpack-dev-server": "^5.2.5",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "overrides": {
    "sockjs": {
      "uuid": "11.1.1"
    }
  },
  "scripts": {
    "prelint": "lingui compile",
    "prestart": "lingui compile",
    "pretest": "lingui compile",
    "pretest-watch": "lingui compile",
    "start": "GENERATE_SOURCEMAP=false ESLINT_NO_DEV_ERRORS=true PORT=3001 HTTPS=true DANGEROUSLY_DISABLE_HOST_CHECK=true node scripts/start.js",
    "build": "INLINE_RUNTIME_CHUNK=false node scripts/build.js",
    "test": "TZ='UTC' node scripts/test.js --watchAll=false",
    "test-screens": "TZ='UTC' node scripts/test.js screens --watchAll=false",
    "test-general": "TZ='UTC' node scripts/test.js --testPathIgnorePatterns='<rootDir>/src/screens/' --watchAll=false",
    "test-watch": "TZ='UTC' node scripts/test.js",
    "lint": "NODE_ENV=development eslint .",
    "extract-strings": "lingui extract",
    "extract-template": "lingui extract-template",
    "compile-strings": "lingui compile",
    "prettier": "prettier --cache --write \"src/**/*.{js,jsx,scss}\"",
    "prettier-check": "prettier --cache --check \"src/**/*.{js,jsx,scss}\""
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "jest": {
    "roots": [
      "<rootDir>/src",
      "<rootDir>/testUtils"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}",
      "testUtils/**/*.{js,jsx}"
    ],
    "setupFiles": [
      "<rootDir>/config/jest/textEncoderPolyfill.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.js"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/*.{spec,test}.{js,jsx,ts,tsx}",
      "<rootDir>/testUtils/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(js|jsx|mjs|cjs|ts|tsx)$": "<rootDir>/config/jest/babelTransform.js",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|mjs|cjs|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/(?!d3)/",
      "<rootDir>/node_modules/(?!has-ansi)/"
    ],
    "modulePaths": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "<rootDir>/config/jest/cssModulesTransform.js"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ],
    "resetMocks": true,
    "coveragePathIgnorePatterns": [
      "<rootDir>/src/locales",
      "index.js"
    ]
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
